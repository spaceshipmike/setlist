{
  "name": "setlist",
  "private": true,
  "version": "0.5.4",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/mcp",
    "packages/cli",
    "packages/app"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/cli && npm run build -w packages/mcp",
    "build:core": "npm run build -w packages/core",
    "build:mcp": "npm run build -w packages/mcp",
    "build:cli": "npm run build -w packages/cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p packages/mcp/tsconfig.json",
    "verify:mcp-abi": "bash scripts/verify-mcp-abi.sh"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0"
  },
  "volta": {
    "node": "24.15.0"
  }
}
